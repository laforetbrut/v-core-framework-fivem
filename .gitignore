# ─── FiveM server artifacts (redownloadable binaries, ~1.5 GB) ───
artifacts/

# ─── Runtime cache & server state ───
cache/
*.log
logs/
svadhesive.log

# ─── Secrets / local env ───
license.cfg
*.local
.env

# ─── Local MariaDB launchers + data (machine-specific — never commit) ───
# The framework does not care how your database is started: point
# `mysql_connection_string` at any MySQL/MariaDB. Only schema.sql is shared.
database/data/
database/start-db.ps1
database/stop-db.ps1
start-db.bat
stop-db.bat

# ─── Claude Code (local-only configuration) ───
.claude/
CLAUDE.md

# ─── Test procedure artefacts (local QA only — never push) ───
test-procedures/
TEST_PROCEDURE_*.html

# ─── Scratch / temp working files ───
scratch_*
tmp_*
tmp_clone/
tmp_files/

# ─── OS / editor ───
Thumbs.db
Desktop.ini
.DS_Store
.vscode/
.idea/

# ─── FiveM runtime files ───
.replxx_history

# ─── Generated clothing thumbnails (per-server, rebuilt via /scanclothes) ───
# NOTE: [ ] are escaped — in gitignore they are character classes otherwise.
resources/\[local\]/v-clothing/thumbs/*
!resources/\[local\]/v-clothing/thumbs/.gitkeep

# ─── screenshot-basic build output (generated at boot by yarn/webpack) ───
resources/\[standalone\]/screenshot-basic/dist/
resources/\[standalone\]/screenshot-basic/node_modules/
resources/\[standalone\]/screenshot-basic/.yarn-cache/

# Backed-up previous (deprecated) server artifacts — local only
artifacts.legacy-bak/
.console-history
.id
local-database/
crashes/
svadhesive/

# Generated phone preview (rebuilt from source on demand)
resources/[local]/v-phone/preview/
